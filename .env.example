# Desenvolvimento local (opcional — valores padrão já existem em application.properties)
# DB_PASSWORD=postgres
# REDIS_URL=redis://localhost:6379
# JWT_SIGN_KEY_LOCATION=classpath:keys/privateKey.pem
# JWT_PUBLIC_KEY_LOCATION=classpath:keys/publicKey.pem

# Produção (obrigatório com -Dquarkus.profile=prod)
# DB_USERNAME=
# DB_PASSWORD=
# DB_URL=jdbc:postgresql://host:5432/mec
# REDIS_URL=redis://:senha@host:6379
# JWT_SIGN_KEY_LOCATION=file:/secrets/jwt-private.pem
# JWT_PUBLIC_KEY_LOCATION=file:/secrets/jwt-public.pem
